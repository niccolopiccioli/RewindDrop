# Database
DATABASE_URL="postgresql://eshop:eshop@localhost:5432/eshop?schema=public"

# Auth (required) — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-char-secret"

# Payments — mock (default) or stripe
PAYMENT_MODE=mock
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Image uploads (production — Vercel Blob; omit for local disk storage)
# BLOB_READ_WRITE_TOKEN=

# Email (optional — without SMTP, emails log to console)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=noreply@eshop.local

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Admin inventory threshold (optional)
# LOW_STOCK_THRESHOLD=5
