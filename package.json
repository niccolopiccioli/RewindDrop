    "db:seed-admin": "tsx scripts/seed-admin.ts",
    "db:import-stockx": "tsx scripts/import-stockx-products.ts",
    "db:refresh-images": "tsx scripts/refresh-product-images.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "setup": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
